{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "fetch-data": {
      "inputs": ["scripts/fetch-data.ts"],
      "outputs": ["data/chats/**", "data/stats/**", "data/dicts/**"],
      "cache": true
    },
    "build": {
      "dependsOn": ["^build", "fetch-data"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "check-updates": {
      "outputs": [
        "data/chats/**",
        "data/stats/**",
        "data/dicts/**",
        "data/commit-sha"
      ]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "test": {
      "dependsOn": ["^test", "fetch-data"]
      // "outputs": ["coverage/**"]
    }
  }
}
